<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:focusable="false">

    <com.hades.hKtweaks.views.XYGraph
        android:id="@+id/usage_graph"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <TextView
        android:id="@+id/usage_offline_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:ellipsize="middle"
        android:focusable="false"
        android:gravity="center"
        android:text="@string/offline"
        android:textAllCaps="true"
        android:textAppearance="@style/TextAppearance.HK3475.ItemTitle.Emphasized"
        android:textColor="?attr/colorOnPrimaryContainer"
        android:visibility="gone"
        android:singleLine="true" />

    <TextView
        android:id="@+id/usage_load_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:focusable="false"
        android:padding="3dp"
        android:textAppearance="@style/TextAppearance.HK3475.Label"
        android:textColor="?attr/colorOnPrimaryContainer"
        />

    <TextView
        android:id="@+id/usage_freq_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:focusable="false"
        android:padding="3dp"
        android:textAppearance="@style/TextAppearance.HK3475.Label"
        android:textColor="?attr/colorOnPrimaryContainer"
        />

    <TextView
        android:id="@+id/usage_core_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:focusable="false"
        android:padding="3dp"
        android:textAppearance="@style/TextAppearance.HK3475.Label"
        android:textColor="?attr/colorOnPrimaryContainer"
        />
</FrameLayout>
