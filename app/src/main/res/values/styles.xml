<resources>

    <style name="AppTheme" parent="Theme.Material3Expressive.Light.NoActionBar">
        <item name="preferenceTheme">@style/PreferenceThemeOverlay.HK3475.Material3</item>
        <item name="banner_frame_drawable">@drawable/drawable_frame_light</item>
        <item name="appSurfaceColor">@color/white</item>
        <item name="android:colorBackground">?attr/appSurfaceColor</item>
        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColorSecondary">@color/textcolor_light</item>
        <item name="android:textColorPrimaryInverse">@color/white</item>
