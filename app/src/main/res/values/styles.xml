        <item name="colorSecondaryFixedDim">?attr/colorAccent</item>
        <item name="colorOnSecondaryFixed">@color/black</item>
        <item name="colorOnSecondaryFixedVariant">@color/black</item>
        <item name="colorOnTertiary">@color/black</item>
        <item name="colorOnTertiaryContainer">@color/black</item>
        <item name="colorTertiaryContainer">?attr/colorAccent</item>
        <item name="colorOnBackground">@color/black</item>
        <item name="colorSurface">?attr/appSurfaceColor</item>
        <item name="colorSurfaceVariant">?attr/appSurfaceColor</item>
        <item name="colorSurfaceBright">?attr/appSurfaceColor</item>
        <item name="colorSurfaceDim">?attr/appSurfaceColor</item>
        <item name="colorSurfaceContainer">?attr/appSurfaceColor</item>
        <item name="colorSurfaceContainerLow">?attr/appSurfaceColor</item>
        <item name="colorSurfaceContainerHigh">?attr/appSurfaceColor</item>
