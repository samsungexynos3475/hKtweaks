<?xml version="1.0" encoding="utf-8"?>
<resources>

    <declare-styleable name="XYGraph">
        <attr name="linecolor" format="color" />
        <attr name="edgecolor" format="color" />
        <attr name="edgestrokewidth" format="dimension" />
        <attr name="graphcolor" format="color" />
        <attr name="graphstrokewidth" format="color" />
        <attr name="edgevisibile" format="boolean" />
    </declare-styleable>

    <declare-styleable name="BorderCircleView">
        <attr name="circlecolor" format="color" />
        <attr name="bordercolor" format="color" />
    </declare-styleable>

    <attr name="banner_frame_drawable" format="reference" />
    <attr name="native_express_id" format="string" />
    <attr name="dim_dialog_background" format="color" />
    <attr name="appSurfaceColor" format="color" />
	
	<!-- Grx Sound Control -->
    <declare-styleable name="VolumeItemController">
        <attr name="wheelsize" format="dimension|reference"></attr>
        <attr name="refVal" format="integer|reference"></attr>
        <attr name="valStep" format="integer|reference"></attr>
        <attr name="refValposition" format="integer|reference"/>
        <attr name="label" format="string|reference"></attr>
    </declare-styleable>

</resources>
